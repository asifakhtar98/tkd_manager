{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🚀 Dev (Web / Chrome)",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "-d", "chrome",
                "--web-port", "51885"
            ]
        },
        {
            "name": "🚀 Dev (WASM / Chrome)",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "-d", "chrome",
                "--wasm",
                "--web-port", "51886"
            ]
        },
        {
            "name": " Dev (iPad / iOS Simulator)",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "-d", "ipad"
            ]
        },
        {
            "name": "📊 Profile Mode (Chrome)",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "flutterMode": "profile",
            "args": [
                "-d", "chrome",
                "--web-port", "51885"
            ]
        },
        {
            "name": "🏭 Release Mode (Chrome)",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "flutterMode": "release",
            "args": [
                "-d", "chrome",
                "--web-port", "51885"
            ]
        },
        {
            "name": "🔌 Attach to Flutter",
            "cwd": "${workspaceFolder}",
            "request": "attach",
            "type": "dart"
        }
    ]
}